APP_NAME=AI Recipe Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=ai_recipe_app

# Use a server-side key, never expose this in mobile/web clients.
OPENAI_API_KEY=sk-...
OPENAI_MODEL_RECIPES=gpt-4.1-mini
OPENAI_MODEL_VISION=gpt-4.1-mini

CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-domain>
CLERK_AUDIENCE=

# Comma-separated values, e.g. http://localhost:8081,http://localhost:19006
CORS_ORIGINS=http://localhost:8081
