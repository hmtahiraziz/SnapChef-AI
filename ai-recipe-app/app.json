{
  "expo": {
    "name": "SnapChef AI",
    "slug": "ai-recipe-app",
    "version": "1.0.0",
    "owner": "technology726",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "airecipeapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSCameraUsageDescription": "Snap photos of ingredients to find recipes.",
        "NSPhotoLibraryUsageDescription": "Choose ingredient photos from your library."
      }
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1E1633",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.technology726.airecipeapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Snap photos of ingredients to find recipes.",
          "photosPermission": "Choose ingredient photos from your library."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#8966FA",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 148,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cf654699-ddff-4d9e-b016-cfa7c1007b70"
      }
    }
  }
}
