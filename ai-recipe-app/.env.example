# Optional: The base URL of the FastAPI backend.
# In development, this is automatically detected using Expo's hostUri (falling back to http://localhost:8000).
# You only need to set this explicitly for production builds, ngrok tunnels, or custom deployment configurations.
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Clerk Publishable Key (Required for user authentication)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
