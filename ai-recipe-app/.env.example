# network cannot reach it. Set a public HTTPS API URL in the Expo dashboard instead:
#   Project → Environment variables → preview / production → EXPO_PUBLIC_API_BASE_URL
#
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

